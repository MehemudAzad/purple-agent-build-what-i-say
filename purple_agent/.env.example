# Purple Agent — environment configuration
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-open-ai-api-key-here

# ── Optional: model ───────────────────────────────────────────────────────────
PURPLE_MODEL=gpt-4o
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/

# ── Optional: tuning ──────────────────────────────────────────────────────────
PURPLE_TEMPERATURE=0.2
PURPLE_MAX_TOKENS=1024
OPENAI_TIMEOUT=60

# ── Optional: debug ───────────────────────────────────────────────────────────
# Set to 1 to enable verbose logging
AGENT_DEBUG=0
